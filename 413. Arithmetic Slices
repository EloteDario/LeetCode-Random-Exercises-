class Solution(object):
    def numberOfArithmeticSlices(self, nums):
        if len(nums) < 3:
            return 0


        secuenciasTotales = 0
        start = 0
        
        for end in range(2, len(nums)):

            if nums[end] - nums[end - 1] == nums[end - 1] - nums[end - 2]:
                secuenciasTotales += (end - start - 1)
            else:
                start = end - 1
                
        return secuenciasTotales

